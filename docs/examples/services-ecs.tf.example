module "ecs_service_orders" {
  source = "../../modules/ecs-service"

  name               = "orders"
  cluster_name       = "${var.region}-main"
  cpu                = 512
  memory             = 1024
  desired_count      = 2
  container_image    = "public.ecr.aws/docker/library/nginx:latest"
  container_port     = 80
  subnet_ids         = module.vpc.private_subnet_ids
  security_group_ids = [module.sg_ec2.id]
}